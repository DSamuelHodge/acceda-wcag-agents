{
  "$schema": "https://raw.githubusercontent.com/cloudflare/workers-sdk/main/packages/wrangler/config-schema.json",
  "name": "acceda-agents",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-01",
  "compatibility_flags": ["nodejs_compat"],

  // ── Durable Objects ───────────────────────────────────────────────────────
  "durable_objects": {
    "bindings": [
      {
        "name": "AUDIT_AGENT",
        "class_name": "AuditAgent",
        "script_name": "acceda-agents"
      },
      {
        "name": "SENTINEL_AGENT",
        "class_name": "SentinelAgent",
        "script_name": "acceda-agents"
      }
    ]
  },

  // ── Workflows ─────────────────────────────────────────────────────────────
  "workflows": [
    {
      "name": "acceda-audit-workflow",
      "binding": "AUDIT_WORKFLOW",
      "class_name": "AuditWorkflow",
      "script_name": "acceda-agents"
    },
    {
      "name": "acceda-remediation-workflow",
      "binding": "REMEDIATION_WORKFLOW",
      "class_name": "RemediationWorkflow",
      "script_name": "acceda-agents"
    }
  ],

  // ── KV Namespaces ─────────────────────────────────────────────────────────
  "kv_namespaces": [
    {
      "binding": "ACCEDA_CACHE",
      "id": "4f7e1ab1b9f440128f03ac362614afb2",
      "preview_id": "18dd436c27914c5d859335e85cfa18a4"
    },
    {
      "binding": "AUDIT_KV",
      "id": "28fb6c83df7144169e7b498d6a5d69f5"
    },
    {
      "binding": "ACCEDA_SESSIONS",
      "id": "144cf5432c834276bf7e5e056ffadda3"
    }
  ],

  // ── D1 Databases ──────────────────────────────────────────────────────────
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "acceda-db",
      "database_id": "b0f81f03-df05-4f7d-8a2b-aee91c6c7661",
      "preview_database_id": "2b4663bf-a5c0-43c9-85b8-01c47bca2f50"
    }
  ],

  // ── R2 Buckets ────────────────────────────────────────────────────────────
  "r2_buckets": [
    {
      "binding": "SNAPSHOTS",
      "bucket_name": "acceda-snapshots"
    }
  ],

  // ── External MCP Tool Bindings ────────────────────────────────────────────
  // These declare outbound Worker Service bindings to MCP servers
  "services": [
    {
      "binding": "PLAYWRIGHT_MCP",
      "service": "acceda-playwright-mcp"
    }
  ],

  // ── AI Gateway ────────────────────────────────────────────────────────────
  "ai": {
    "binding": "AI"
  },

  // ── Environment Variables ─────────────────────────────────────────────────
  "vars": {
    "WCAG_LEVEL": "wcag2aa",
    "MAX_ELEMENTS": "30",
    "ENVIRONMENT": "production",
    "AI_GATEWAY_ID": "acceda-gateway",
    "AXE_CDN": "https://cdnjs.cloudflare.com/ajax/libs/axe-core/4.9.1/axe.min.js"
  },

  // ── Secrets (set via: wrangler secret put KEY) ────────────────────────────
  // ANTHROPIC_API_KEY
  // GITHUB_TOKEN
  // WEBHOOK_SECRET

  // ── Dev Environment ───────────────────────────────────────────────────────
  "env": {
    "development": {
      "name": "acceda-agents-dev",
      "vars": {
        "WCAG_LEVEL": "wcag2aa",
        "MAX_ELEMENTS": "10",
        "ENVIRONMENT": "development"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "acceda-db-dev",
          "database_id": "2b4663bf-a5c0-43c9-85b8-01c47bca2f50"
        }
      ],
      "kv_namespaces": [
        {
          "binding": "ACCEDA_CACHE",
          "id": "18dd436c27914c5d859335e85cfa18a4"
        }
      ]
    }
  }
}
